{
  "name": "geeny",
  "version": "1.0.0",
  "projectId": "e1iohf8g",
  "globalStyles": "./src/global.css",
  "components": [
    {
      "id": "e1iohf8g-qWMu0qYHyN",
      "name": "Example Component",
      "entry": "./src/components/ExampleComponent/index.tsx",
      "styles": "./src/components/ExampleComponent/styles.css",
      "props": [
        {
          "name": "title",
          "displayName": "Title",
          "type": "TEXT",
          "required": true,
          "defaultValue": "Hello World",
          "description": "The main title text"
        },
        {
          "name": "description",
          "displayName": "Description",
          "type": "TEXT",
          "required": false,
          "defaultValue": "This is an example ikas code component built with Preact.",
          "description": "The description text below the title"
        },
        {
          "name": "showButton",
          "displayName": "Show Button",
          "type": "BOOLEAN",
          "required": false,
          "defaultValue": true,
          "description": "Whether to show the action button"
        },
        {
          "name": "buttonText",
          "displayName": "Button Text",
          "type": "TEXT",
          "required": false,
          "defaultValue": "Click Me",
          "description": "The text displayed on the button"
        }
      ]
    },
    {
      "id": "e1iohf8g-k18BrjeoWP",
      "name": "Example Section",
      "entry": "./src/components/ExampleSection/index.tsx",
      "styles": "./src/components/ExampleSection/styles.css",
      "type": "section",
      "props": [
        {
          "name": "heading",
          "displayName": "Heading",
          "type": "TEXT",
          "required": true,
          "defaultValue": "Welcome to Our Store",
          "description": "The section heading text",
          "groupId": "content"
        },
        {
          "name": "subtitle",
          "displayName": "Subtitle",
          "type": "TEXT",
          "required": false,
          "defaultValue": "Discover our latest products and collections.",
          "description": "The subtitle text below the heading",
          "groupId": "content"
        },
        {
          "name": "backgroundColor",
          "displayName": "Background Color",
          "type": "COLOR",
          "required": false,
          "description": "The section background color",
          "groupId": "appearance"
        }
      ],
      "propGroups": [
        {
          "id": "content",
          "name": "Content",
          "description": "Text and copy settings"
        },
        {
          "id": "appearance",
          "name": "Appearance",
          "description": "Colors and visual style"
        }
      ]
    },
    {
      "id": "e1iohf8g-Button",
      "name": "Button",
      "entry": "./src/components/Button/index.tsx",
      "styles": "./src/components/Button/styles.css",
      "props": [
        {
          "name": "text",
          "displayName": "Buton Metni",
          "type": "TEXT",
          "required": false,
          "defaultValue": "İncele",
          "description": "Buton üzerinde görünecek metin",
          "groupId": "button_group"
        },
        {
          "name": "variant",
          "displayName": "Buton Varyantı",
          "type": "ENUM",
          "options": ["PRIMARY", "SECONDARY", "ACCENT"],
          "required": false,
          "defaultValue": "PRIMARY",
          "description": "Butonun görsel stili (Primary Navy, Accent Sarı veya Secondary Şeffaf)",
          "groupId": "button_group"
        },
        {
          "name": "link",
          "displayName": "Buton Bağlantısı",
          "type": "LINK",
          "required": false,
          "description": "Tıklandığında yönlendirilecek sayfa veya harici link",
          "groupId": "button_group"
        },
        {
          "name": "fullWidth",
          "displayName": "Tam Genişlik",
          "type": "BOOLEAN",
          "required": false,
          "defaultValue": false,
          "description": "Buton kapsayıcısının tüm genişliğini kaplasın",
          "groupId": "button_group"
        },
        {
          "name": "size",
          "displayName": "Buton Boyutu",
          "type": "ENUM",
          "options": ["NORMAL", "LARGE"],
          "required": false,
          "defaultValue": "NORMAL",
          "description": "Standart (48px) veya Geniş/Checkout (52px)",
          "groupId": "button_group"
        }
      ],
      "propGroups": [
        {
          "id": "button_group",
          "name": "Buton Ayarları",
          "description": "Buton metni, stili ve yönlendirme ayarları"
        }
      ]
    }
  ]
}
